# Web3Forms access key — get a free one at https://web3forms.com (no account/signup required).
# This key is designed to be public-safe (rate-limited and domain-scoped server-side by Web3Forms),
# so it is intentionally prefixed with NEXT_PUBLIC_ and used directly from the client.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-access-key-here

# Public production URL of the site, used for metadata/sitemap/robots/JSON-LD. Update after deploying.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
